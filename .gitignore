__pycache__/
*.pyc
.venv/
.pytest_cache/
.DS_Store

# Build artefacts from `pip install -e .` and `python -m build`.
*.egg-info/
build/
dist/

# Local ruff cache; the lint config lives in pyproject.toml.
.ruff_cache/

# Node + ESLint toolchain (only used by the lint-js CI job; the
# dashboard ships zero JS dependencies and has no build step).
node_modules/

# Generated dashboard payloads. metrics.json, diffs.json and
# asn-names.json are built fresh on every Pages deploy from
# bitcoin-core/asmap-data + bgp.tools; see README for the regen
# commands used locally. network.json is the one exception: it is
# derived from KIT dossiers CI has no access to, so the small
# aggregate file is committed until the raw data can be published.
/web/assets/data/*.json
!/web/assets/data/network.json
.firecrawl/

# Local checkout of bitcoin-core/asmap-data used to run the pipeline; it
# carries its own git history and is cloned fresh on deploy, never tracked.
/asmap-data/
